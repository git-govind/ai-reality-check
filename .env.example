# ──────────────────────────────────────────────────────────────
# AI Reality Check — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# Ollama base URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible API (optional – for cloud LLMs)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Default evaluation LLM (used as judge/critic)
EVAL_MODEL=mistral

# Wikipedia user-agent string
WIKI_USER_AGENT=AIRealityCheck/1.0

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
